<html>
<head>
<style>
svg { width: 200px; height: 280px; }
</style>
</head>
<body>
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 280">
  <rect width="200" height="280" fill="#e9ecef"/>
  <rect x="20" y="20" width="160" height="160" fill="#dee2e6"/>
  <circle cx="100" cy="70" r="20" fill="#adb5bd"/>
  <polygon points="50,140 100,90 150,140" fill="#adb5bd"/>
  <text x="100" y="220" font-family="Arial" font-size="14" text-anchor="middle" fill="#6c757d">Tidak Ada Gambar</text>
</svg>
</body>
</html>
